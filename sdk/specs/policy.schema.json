{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eaasp.dev/schemas/policy.schema.json",
  "title": "Policy",
  "description": "EAASP Policy — enterprise governance rules for Skill execution.",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "default": "1.0.0" },
    "description": { "type": "string", "default": "" },
    "author": { "type": "string", "default": "" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "condition"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "default": "" },
          "condition": { "type": "string", "minLength": 1 },
          "action": {
            "type": "string",
            "enum": ["allow", "deny", "audit", "modify"],
            "default": "deny"
          },
          "priority": { "type": "integer", "default": 100 },
          "scope": {
            "type": "string",
            "enum": ["global", "bu", "dept", "team"],
            "default": "global"
          }
        }
      },
      "default": []
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    }
  }
}
